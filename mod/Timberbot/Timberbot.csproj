    </Reference>
    <Reference Include="Timberborn.WeatherSystem" Publicize="true">
      <HintPath>$(GameManagedDir)\Timberborn.WeatherSystem.dll</HintPath>
    </Reference>
    <Reference Include="Timberborn.WorldPersistence" Publicize="true">
